# Database Configuration
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@127.0.0.1:5432/financial_analysis

# Security — ОБЯЗАТЕЛЬНО сгенерируйте уникальный ключ:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_secrets_token_hex_32

# Email Configuration (Mail.ru SMTP)
SMTP_SERVER=smtp.mail.ru
SMTP_PORT=587
SMTP_USERNAME=your_email@mail.ru
SMTP_PASSWORD=your_app_password
USE_REAL_EMAIL=false

# AI Configuration (optional)
CLAUDE_API_KEY=
OLLAMA_HOST=http://localhost:11434

# Debug mode (set to false in production)
DEBUG=true
