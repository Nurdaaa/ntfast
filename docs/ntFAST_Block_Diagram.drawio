        <!-- ===== BENEFITS TO STATE ===== -->
        <mxCell id="benLabel" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;МЕМЛЕКЕТКЕ ТИГІЗЕТІН ПАЙДА&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="390" width="240" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ben1" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;💰 ЭКОНОМИКАЛЫҚ ПАЙДА&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;• &lt;b&gt;Импорт алмастыру&lt;/b&gt; — шетелдік бағдарламалық&lt;br&gt;  қамтамасыз ету орнына отандық шешім&lt;br&gt;  (жылына $200K – $1M үнемдеу)&lt;br&gt;&lt;br&gt;• &lt;b&gt;Алаяқтықтан қорғау&lt;/b&gt; — жылына&lt;br&gt;  15–40 млрд ₸ шығынның алдын алу&lt;br&gt;&lt;br&gt;• &lt;b&gt;Жұмыс орындары&lt;/b&gt; — IT саласында&lt;br&gt;  20–30 жаңа жұмыс орны&lt;br&gt;&lt;br&gt;• &lt;b&gt;Экспорт потенциалы&lt;/b&gt; — ТМД, ЕАЭО&lt;br&gt;  елдеріне (Қырғызстан, Өзбекстан, Алиевкстан)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;strokeWidth=2;shadow=1;fontSize=11;arcSize=10;align=left;spacingLeft=15;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="380" height="280" as="geometry" />
        </mxCell>
        <mxCell id="ben2" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;🏛️ СТРАТЕГИЯЛЫҚ ПАЙДА&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;• &lt;b&gt;ФАТФ бағалауын жақсарту&lt;/b&gt; — Қазақстанды&lt;br&gt;  «сұр тізімнен» алып шығу&lt;br&gt;&lt;br&gt;• &lt;b&gt;ПОД/ФТ жүйесін нығайту&lt;/b&gt; — ақша жылыстатуға&lt;br&gt;  және терроризмді қаржыландыруға қарсы&lt;br&gt;&lt;br&gt;• &lt;b&gt;Мемлекеттік тілді қолдау&lt;/b&gt; — қазақ тілінде&lt;br&gt;  толық жұмыс істейтін жүйе&lt;br&gt;&lt;br&gt;• &lt;b&gt;«Цифрлы Қазақстан»&lt;/b&gt; — бағдарламаға&lt;br&gt;  толық сәйкестік&lt;br&gt;&lt;br&gt;• &lt;b&gt;Деректер егемендігі&lt;/b&gt; — деректер ел ішінде&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;strokeWidth=2;shadow=1;fontSize=11;arcSize=10;align=left;spacingLeft=15;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="460" y="420" width="380" height="280" as="geometry" />
        </mxCell>
        <mxCell id="ben3" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;🛡️ ҚАУІПСІЗДІК ПАЙДАСЫ&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;• &lt;b&gt;Терроризмді қаржыландыруға&lt;/b&gt; қарсы&lt;br&gt;  күресті нығайту&lt;br&gt;&lt;br&gt;• &lt;b&gt;Ұйымдасқан қылмыстың&lt;/b&gt; қаржы&lt;br&gt;  ағындарын анықтау&lt;br&gt;&lt;br&gt;• &lt;b&gt;Салық жалтару&lt;/b&gt; схемаларын ашу&lt;br&gt;&lt;br&gt;• &lt;b&gt;Коррупциялық ақша&lt;/b&gt; ағындарын бақылау&lt;br&gt;&lt;br&gt;• &lt;b&gt;Трансшекаралық&lt;/b&gt; қаржы&lt;br&gt;  ағындарын мониторинг&lt;br&gt;&lt;br&gt;• &lt;b&gt;Кибер-алаяқтыққа&lt;/b&gt; қарсы қорғаныс&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;strokeWidth=2;shadow=1;fontSize=11;arcSize=10;align=left;spacingLeft=15;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="880" y="420" width="380" height="280" as="geometry" />
        </mxCell>
        <!-- ===== COMPLIANCE STANDARDS ===== -->
        <mxCell id="compLabel" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;СӘЙКЕСТІК СТАНДАРТТАРЫ&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="720" width="210" height="25" as="geometry" />
        </mxCell>
        <mxCell id="comp1" value="&lt;b&gt;ФАТФ (FATF)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;40 ұсыныс | 11 тікелей нәтиже&lt;br&gt;Risk-Based Approach&lt;br&gt;Customer Due Diligence (CDD)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3f51b5;strokeWidth=2;shadow=1;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="750" width="280" height="80" as="geometry" />
